{
  "name": "@antv/context",
  "version": "0.1.0",
  "description": "A local context retrieval library that enables semantic search over your documentation. It loads documents (Markdown, JSON, Text), vectorizes them using [Transformers.js](https://huggingface.co/transformers.js), and stores vectors locally in `.zvec` files for fast semantic querying. ",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "HF_ENDPOINT=https://hf-mirror.com vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'"
  },
  "keywords": [
    "context",
    "semantic-search",
    "embedding",
    "vector",
    "transformers",
    "huggingface",
    "zvec",
    "antv"
  ],
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@zvec/zvec": "^0.5.0",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.6"
  },
  "repository": "git@github.com:antvis/context.git",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
